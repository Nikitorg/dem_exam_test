<Window x:Class="demExam.Windows.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:demExam.Windows"
        mc:Ignorable="d"
        Title="ООО Обувь - Меню" MinHeight="400" MinWidth="400" WindowStartupLocation="CenterScreen" Height="400" Width="400" Icon="/Assets/Icon.ico">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="22"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="22"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Background" Value="#7FFF00"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100*"/>
            <RowDefinition Height="300*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200*"/>
                <ColumnDefinition Width="200*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Меню" VerticalAlignment="Bottom" Grid.ColumnSpan="2" HorizontalAlignment="Center"/>
            <StackPanel Grid.Column="1">
                <TextBlock FontSize="14" x:Name="userTxt" HorizontalAlignment="Center"/>
                <Button Content="Назад" Background="#00FA9A" Width="100" Click="BackBtn_Click"/>
            </StackPanel>
            
        </Grid>
        <StackPanel Grid.Row="1" Margin="10">
            <Button Content="Товары" FontSize="22" Margin="10" Click="productView_Click"/>
            <Button Content="Заказы" FontSize="22" Margin="10" Click="orderVIew_Click"/>
        </StackPanel>
    </Grid>
    
</Window>
