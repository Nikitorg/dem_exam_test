<Window x:Class="demExam.Windows.addProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:demExam.Windows"
        mc:Ignorable="d"
        Title="ООО Обувь - Добавление товара" Height="850" WindowStartupLocation="CenterScreen" Width="500" MinHeight="600" MinWidth="500">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="22"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="22"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Background" Value="#7FFF00"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50*"/>
            <RowDefinition Height="900*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300*"/>
                <ColumnDefinition Width="200*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Добавление товара" HorizontalAlignment="Center" Grid.ColumnSpan="2" VerticalAlignment="Bottom"/>
            <StackPanel Grid.Column="1">
                <TextBlock FontSize="14" x:Name="userTxt" HorizontalAlignment="Center"/>
                <Button HorizontalAlignment="Right" Content="Назад" Background="#00FA9A" Width="100" Click="BackBtn_Click"/>
            </StackPanel>
        </Grid>
        <StackPanel Grid.Row="1">
            <Image Source="/Assets/picture.png" Width="100" Height="100"  HorizontalAlignment="Left"/>
            <StackPanel Margin="5">
                <TextBlock Text="Артикул"/>
                <TextBox Tag="Артику" x:Name="articleProductTxtBox"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Наименование товара"/>
                <TextBox Tag="Наименование товара" x:Name="nameProdctTxtBox"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Категория товара"/>
                <ComboBox Tag="Категория товара" FontSize="20" Name="catCmbBox"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Описание товара"/>
                <TextBox Tag="Описание товара" x:Name="infoProductTxtBox"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Производитель"/>
                <ComboBox Tag="Производитель" FontSize="20" Name="proizCmbBox"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Поставщик"/>
                <TextBox Tag="Поставщик" x:Name="postavProductTxtBox"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Цена"/>
                <TextBox Tag="Цена" x:Name="priceProductTxtBox"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Единица измерения"/>
                <TextBox Tag="Единица измерения" x:Name="edProductTxtBox"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Количество на складе"/>
                <TextBox Tag="Количество на складе" x:Name="countProductTxtBox"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Действующая скидка"/>
                <TextBox Tag="Действующая скидка" x:Name="actionProductTxtBox"/>
            </StackPanel>
            <Button Content="Сохранить" FontSize="22" Margin="5" Click="SaveProduct_Click"/>
        </StackPanel>
    </Grid>
</Window>
