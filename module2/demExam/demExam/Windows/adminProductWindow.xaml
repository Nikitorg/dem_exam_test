<Window x:Class="demExam.Windows.adminProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:demExam.Windows"
        mc:Ignorable="d"
                Title="ООО Обувь - Список товаров (администратор)" Height="450" Width="1000" MinHeight="450" MinWidth="1000" WindowStartupLocation="CenterScreen" Icon="/Assets/Icon.ico">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="22"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="22"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Background" Value="#7FFF00"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200*"/>
            <ColumnDefinition Width="800*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50*"/>
            <RowDefinition Height="400*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="600*"/>
                <ColumnDefinition Width="200*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Товары" Grid.ColumnSpan="2" HorizontalAlignment="Center"/>
            <StackPanel Grid.Column="1">
                <TextBlock FontSize="14" x:Name="userTxt" HorizontalAlignment="Center"/>
                <Button Content="Назад" Background="#00FA9A" Width="100" Click="BackBtn_Click"/>
            </StackPanel>
        </Grid>
        <DataGrid x:Name="dgProduct" Grid.Row="1" Grid.Column="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="dgProduct_SelectionChanged">

            <!--ВОТ КОД ТРИГЕРА ПОКРАСКИ СТРОКИ В СЛУЧАЕ Скидка >15 И ОТСУТСТВИЕ ТОВАРА НА СКЛАДЕ-->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding checkActionCollor}" Value="True">
                            <Setter Property="Background" Value="#2E8B57"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding checkCountProduct}" Value="True">
                            <Setter Property="Background" Value="#42AAFF"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTemplateColumn Width="200*" Header="Фото">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image Source="{Binding isImageLoad}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Width="400*" Header="Описание">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontWeight="Bold" Text="{Binding КатегорияТовара}"/>
                                    <TextBlock Text=" | " FontWeight="Bold"/>
                                    <TextBlock FontWeight="Bold" Text="{Binding НаименованиеТовара}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Описание товара: "/>
                                    <TextBlock Text="{Binding ОписаниеТовара}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Производитель: "/>
                                    <TextBlock Text="{Binding Производитель}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Поставщик: "/>
                                    <TextBlock Text="{Binding Поставщик}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Цена: "/>

                                    <!--КОД ПЕРЕКРАСКИ И ПЕРЕЧЕРКИВАНИЯ ЦЕНЫ И РЯДОМ ВЫВОД НОВОЙ-->
                                    <TextBlock Text="{Binding Цена}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding checkPriceCollor}" Value="true">
                                                        <Setter Property="Foreground" Value="Red"/>
                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text=" "/>
                                    <TextBlock Text="{Binding newPriceAction}" Visibility="Visible">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding checkPriceCollor}" Value="true">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Единица измерения: "/>
                                    <TextBlock Text="{Binding ЕдиницаИзмерения}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Количество на складе: "/>
                                    <TextBlock Text="{Binding КоличествоНаСкладе}"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn FontFamily="Times New Roman" Width="200*" FontSize="22" Header="Скидка" Binding="{Binding ДействующаяСкидка}"/>

            </DataGrid.Columns>
        </DataGrid>
        <!--БЛОК ПОИСКА, ФИЛТРАЦИИ, СОРТИРОВКИ-->
        <StackPanel Grid.Row="1" Margin="5">
            <TextBlock FontSize="16" Text="Поиск" HorizontalAlignment="Center"/>

            <TextBox x:Name="selectProductTxtBox" TextChanged="selectProduct_TextChanged" />

            <TextBlock FontSize="16" Text="Количество на складе" HorizontalAlignment="Center"/>
            <RadioButton x:Name="rbUp" GroupName="count" Margin="5" Content="По возрастанию" Checked="checkCount_Rbtn"/>
            <RadioButton x:Name="rbDown" GroupName="count" Margin="5" Content="По убыванию" Checked="checkCount_Rbtn"/>

            <TextBlock FontSize="16" Text="Поставщики" HorizontalAlignment="Center"/>
            <ComboBox Margin="5" Name="cmbPostav" SelectedIndex="0" SelectionChanged="cmbPostav_SelectionChanged" />

            <Button Content="Добавить товар" FontSize="22" Margin="10" Click="addProduct_Click"/>
        </StackPanel>
    </Grid>
</Window>
