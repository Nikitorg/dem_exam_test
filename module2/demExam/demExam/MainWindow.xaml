<Window x:Class="demExam.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:demExam"
        mc:Ignorable="d"
        Title="ООО Обувь - Авторизация" MinHeight="450" MinWidth="450" WindowStartupLocation="CenterScreen" Height="450" Width="450" Icon="/Assets/Icon.ico">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontSize" Value="22"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="FontSize" Value="22"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Times New Roman"/>
            <Setter Property="Background" Value="#7FFF00"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100*"/>
            <ColumnDefinition Width="350*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100*"/>
            <RowDefinition Height="350*"/>
        </Grid.RowDefinitions>
        <Image Source="/Assets/Icon.png" VerticalAlignment="Top" />
        <TextBlock Grid.ColumnSpan="2" HorizontalAlignment="Center" FontSize="25"  Text="Авторизация"/>
        <StackPanel Grid.Row="1">
            <TextBlock Text="Логин" Margin="10"  HorizontalAlignment="Right"/>
            <TextBlock Text="Пароль" Margin="10" HorizontalAlignment="Right"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.Column="1">
            <TextBox x:Name="logTxtBox" Margin="10"/>
            <PasswordBox FontSize="22" Name="passPsBox" Margin="10"/>
        </StackPanel>
        <StackPanel Margin="50 150 50 0" Grid.Row="1" Grid.ColumnSpan="2">
            <Button Content="Войти" FontSize="22" Click="btnAutoriz_Click"/>
            <Button Margin="0 20 0 0" Click="btnAutorizGost_Click" Content="Войти гостем" Background="#00FA9A" FontSize="22"/>
        </StackPanel> 
    </Grid>
</Window>
